<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D1D9FF"
    android:padding="24dp"
    tools:context=".tugas_4.FourthCustom1Activity">

    <TextView
        android:id="@+id/tvTitleCustom1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard Info"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2962FF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDescCustom1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selamat datang di aplikasi Nopi Swirl 👋\nTemukan informasi dokter terbaikmu di sini."
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="32dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="25dp"
        app:cardBackgroundColor="#E0E5FF"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    app:cardCornerRadius="45dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/dokter"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_bulat"
                        android:backgroundTint="#2962FF"
                        android:padding="8dp"
                        android:text="15 years experience"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_bulat"
                        android:backgroundTint="#2962FF"
                        android:padding="8dp"
                        android:text="Focus: Skin conditions, acne, and hormonal imbalances."
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_bulat"
                android:backgroundTint="#FFFFFF"
                android:gravity="center"
                android:padding="10dp"
                android:text="Dr. Alexander Bennett, Ph.D.\nDermato-Genetics"
                android:textColor="#2962FF"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="⭐ 5  |  💬 40  |  🕒 9AM - 5PM"
                android:textColor="#2962FF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_bulat"
                android:backgroundTint="#2962FF"
                android:paddingHorizontal="30dp"
                android:paddingVertical="10dp"
                android:text="Schedule"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>